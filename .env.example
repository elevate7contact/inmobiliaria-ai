# =============================================================================
# inmobiliaria-ai · variables de entorno
# =============================================================================
# Copia este archivo a `.env` y rellena cada valor con las credenciales reales.
# Nunca subas el archivo `.env` a GitHub (está en .gitignore).
#
# Para obtener cada valor revisá la sección correspondiente abajo.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE — Postgres de Supabase
# -----------------------------------------------------------------------------
# Connection string completa para Prisma. Incluye el password del proyecto.
#
# Dónde obtenerlo:
#   Supabase Dashboard → Project Settings → Database
#   → Connection string → URI mode (NO el "Connection pooling" para dev)
#
# Formato:
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=


# -----------------------------------------------------------------------------
# SUPABASE — Cliente público (frontend)
# -----------------------------------------------------------------------------
# URL del proyecto. Pública, va embebida en el cliente.
# Dónde: Supabase Dashboard → Project Settings → API → "Project URL"
NEXT_PUBLIC_SUPABASE_URL=

# Anon key. Pública, segura para frontend (RLS la valida en cada query).
# Dónde: Supabase Dashboard → Project Settings → API → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# -----------------------------------------------------------------------------
# SUPABASE — Service role (BACKEND ONLY · NUNCA en cliente)
# -----------------------------------------------------------------------------
# Bypass RLS para operaciones admin desde server (signup, webhooks, etc.).
# Si esto se filtra, cualquiera puede leer/borrar toda la DB. Tratar como contraseña.
#
# Dónde: Supabase Dashboard → Project Settings → API → "service_role"
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# SESSION — JWT signing secret (Sprint 2 · auth)
# -----------------------------------------------------------------------------
# String aleatorio de mínimo 32 chars que firma los JWT de sesión.
# Si esto cambia, todas las sesiones activas se invalidan (los users tienen
# que loguearse de nuevo). Generar con:
#
#   openssl rand -base64 32
#
# O en Node: crypto.randomBytes(32).toString('base64')
SESSION_SECRET=


# -----------------------------------------------------------------------------
# ANTHROPIC — Claude API (Sprint 3 — search semántico)
# -----------------------------------------------------------------------------
# Dónde: https://console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# STRIPE — Pagos y suscripciones (Sprint 5)
# -----------------------------------------------------------------------------
# Test mode primero (pk_test_..., sk_test_...). Pasar a live solo en deploy final.
#
# Dónde: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret. Se obtiene cuando creás el endpoint del webhook.
# Dónde: Stripe Dashboard → Developers → Webhooks → [endpoint creado] → Signing secret
STRIPE_WEBHOOK_SECRET=

# Price IDs de los 3 planes. Crear los productos en Stripe primero.
# Dónde: Stripe Dashboard → Products → Add product → copy price ID
STRIPE_PRICE_PLAN_20=
STRIPE_PRICE_PLAN_50=
STRIPE_PRICE_PLAN_100=


# -----------------------------------------------------------------------------
# APP — Configuración general
# -----------------------------------------------------------------------------
# URL pública del sitio. En dev es localhost, en producción el dominio real.
# Se usa para callbacks de Stripe y links en emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Entorno actual (development | production)
NODE_ENV=development
